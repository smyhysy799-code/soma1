<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
<link rel="stylesheet" href="style.css">



</head>
        
        
        
<body>
      
    <nav class="navbar">
<div class="logo">العطور الفاخرة</div>
<ul class="nav-links">
    <li><a href="#">الرئيسية</a></li>
    <li><a href="#">المنتجات</a></li>
    <li><a href="#">من نحن</a></li>
</ul>
<div class="cart">🛒 السلة</div>
    </nav>
    



 <div class="product">
    <img src="images/pps.jpg">
    <h1 class="welcome-text">welcome to our store</h1>
    </div>


<section class="products-container">  <!--هذا هو الصندوق الكبير اللي يجمع كل العطور-->
<div class="product-card"> <!--بداية كرت العطر الاول-->
    <img src="images/s1.webp"> <!--صورة العطر-->
<h3>عطر رويال</h3> <!--اسم العطر-->
<p class="price">250 ريال</p> <!--السعر اعطيناه كلاس عشان نلونه لالسي اس اس-->
<button class="add-to-cart">أضف إلى السلة</button> <!--زر لانشاء التفاعل-->
</div> <!--نهاية كرت العطر الاول-->

<div class="product-card"> <!--بداية كرت العطر الثاني-->
    <img src="images/s3.png">
<h3>عطر العود الفاخر</h3>
<p class="price">300 ريال</p>
<button class="add-to-cart">أضف إلى السلة</button>
</div> <!--نهاية كرت العطر الثاني-->


<div class="product-card"> <!--بداية كرت العطر الثالث-->
    <img src="images/s5.png">
<h3>عطر الورد</h3>
<p class="price">180 ريال</p>
<button class="add-to-cart">أضف إلى السلة</button>
</div> <!--نهاية كرت العطر الثالث-->
</section>

<section class="features"> <!--هذا الصندوق الكبير اللي يضم المميزات الثلاثة-->
    <div class="feature-item"> <!--هذا الصندوق الصغير لكل ميزة لحالها لذلك عدناه 3 مرات مرة للتوصيل ومرة للجودة ومرة للدفع-->
    <span>🚚</span> <!--هذا الوسم يستخدم للاشياء الصغيرة مثل الايموجي-->
<h4>توصيل سريع</h4>
<p>لكل أنحاء المملكة</p>
    </div>

<div class="feature-item">
<span>💎</span>
<h4>جودة عالية</h4>
<p>منتجات مضمونة</p>
</div>

<div class="feature-item">
<span>💳</span>
<h4>دفع آمن</h4>
<p>خيارات دفع متعددة</p>
</div>
</section>

<footer class="footer"> <!--هذا هو تذييل الصفحة وهو وسم دلالي يخبر المتصفح ان هذا هو الجزء السفلي من الصفحة-->
<div class="footer-content"> <!--هذا الصندوق الصغير اللي يضم محتوى التذييل-->
    <p>جميع الحقوق محفوظة لمتجر العطور 2026</p>
    <div class="social-links"> <!--استخدمنا الحرف a لكل منصة انستقرام سناب واتساب-->
        <a href="#">Instagram</a> <!--علامة الهاشتاق تعني"رابط مؤقت" عند انشاء حساب حقيقي نستبدل الهاشتاق برابط حقيقي-->
        <a href="#">Snapchat</a>
        <a href="#">WhatsApp</a>
    </div>
</div>
</footer>


</body>
</html>